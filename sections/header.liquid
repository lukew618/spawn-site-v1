{% if request.page_type contains 'index' %}
  {% assign is_homepage = true %}
{% else %}
  {% assign is_homepage = false %}
{% endif %}
{%- style -%}
  :root {
    --header-height: 80px;
  }

  .header {
    width: 100%;
    padding-left: 8rem;
    padding-right: 8rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: var(--header-height);
    transition: all 0.1s ease;
    position: fixed;
    top: var(--announcement-bar-height);
    left: 0;
    z-index: 90;
    overflow: visible;
    background-color: {% if is_homepage %}transparent{% else %}black{% endif %};
  }

  /* Add padding to body to account for header height */
  body {
    padding-top: {% if is_homepage %}var(--announcement-bar-height){% else %}calc(var(--announcement-bar-height) + var(--header-height)){% endif %};
  }

  /* Add mobile-specific padding */
  @media screen and (max-width: 991px) {
    :root {
      --header-height: 55px;  /* Reduced from 80px */
    }

    body {
      /* For homepage on mobile, only account for announcement bar height */
      padding-top: {% if is_homepage %}var(--announcement-bar-height){% else %}calc(var(--announcement-bar-height) + var(--header-height)){% endif %};
    }

    /* Ensure collection and product pages have correct spacing */
    body:not(.template-index) .main-page-content {
      margin-top: 0;
    }

    /* Adjust header positioning for mobile */
    .header {
      top: {% if is_homepage %}var(--announcement-bar-height){% else %}var(--announcement-bar-height){% endif %};
    }

    /* Ensure mobile menu elements have white text */
    .header__inline-menu--mobile .header__menu-button,
    .mobile-left-group .header__hamburger,
    .mobile-left-group .header__icon--search,
    .mobile-right-group .header__icon {
      color: white;
    }
    
    .header__hamburger svg path {
      stroke: white;
    }
  }

  /* Remove relative positioning from main content */
  main {
    z-index: auto;
  }

  /* Ensure header group stays on top */
  .shopify-section-group-header-group {
    position: relative;
    z-index: 90;
  }

  /* Set text/icon color to white for all pages */
  .header__heading-link,
  .header__icon,
  .header__menu-item {
    color: white;
    transition: color 0.1s ease;
  }

  /* Homepage-specific styles */
  {% if is_homepage %}
    /* Hover states */
    .header__icon:hover,
    .header__menu-item:hover {
      color: white;
    }

    /* Scrolled state */
    body.scrolled-past-header .header {
      background-color: black;
    }

    body.scrolled-past-header .header__heading-link,
    body.scrolled-past-header .header__icon,
    body.scrolled-past-header .header__menu-item {
      color: white;
    }

    /* Hover state for header */
    .header:hover {
      background-color: black;
    }

    .header:hover .header__heading-link,
    .header:hover .header__icon,
    .header:hover .header__menu-item {
      color: white !important;
    }

    .header__menu-item:active,
    .header__menu-item:focus,
    .header__heading-link:active,
    .header__heading-link:focus,
    .header__active-menu-item {
      color: white !important;
    }

    .header__menu-item:hover {
      color: white !important;
    }

    .link--text:hover {
      color: white !important;
    }

  {% endif %}

  /* Cart count bubble */
  .cart-count-bubble {
    background-color: white;
    color: black;
    position: absolute;
    height: 1.7rem;
    width: 1.7rem;
    border-radius: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.9rem;
    bottom: 0.8rem;
    left: 2.2rem;
  }

  /* Left column - Navigation */
  .header__inline-menu {
    display: flex;
    align-items: center;
    height: 100%;
    overflow: visible;
  }

  /* Maintain nav styling for list-menu */
  .header__inline-menu nav {
    width: 100%;
    height: 100%;
  }

  .header__inline-menu .list-menu {
    display: flex;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .header__inline-menu .list-menu > li {
    display: flex;
    align-items: center;
    flex: 1;
  }

  .header__inline-menu .list-menu__item {
    padding: 0;
    text-transform: uppercase;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    width: auto;
    white-space: nowrap;
  }

  /* Add separators between menu items with equal spacing */
  .header__inline-menu .list-menu > li:not(:last-child)::after {
    content: "|";
    padding: 0 1rem;
    color: inherit;
  }

  /* Remove default hover effects */
  .header__menu-item:hover span {
    text-decoration: none;
  }

  .header__menu-item span {
    transition: opacity 0.1s ease;
  }

  /* Set menu button text color to white */
  .header__menu-button {
    color: white;
  }

  {% if is_homepage %}
    .header__menu-item:hover span {
      opacity: 0.8;
    }
  {% endif %}

  /* Hide dropdown arrows */
  .header__menu-item .icon-caret {
    display: none;
  }

  /* Desktop nav hover dropdowns (generic — for non-SHOP items with children) */
  .nav-dropdown {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .nav-dropdown__menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: black;
    list-style: none;
    padding: 0.5rem 0;
    min-width: 180px;
    z-index: 100;
  }

  .nav-dropdown:hover .nav-dropdown__menu,
  .nav-dropdown:focus-within .nav-dropdown__menu {
    display: block;
  }

  .nav-dropdown__item {
    display: block;
    padding: 0.75rem 1.5rem;
    color: white;
    text-decoration: none;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .nav-dropdown__item:hover {
    opacity: 0.8;
  }

  /* Full-width mega menu (SHOP and any item using drawer_menu data) */
  .nav-megamenu-wrapper {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .nav-megamenu {
    display: none;
    position: fixed;
    top: calc(var(--announcement-bar-height, 48px) + var(--header-height, 80px));
    left: 0;
    right: 0;
    background: black;
    padding: 2.5rem 8rem;
    z-index: 99;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-megamenu-wrapper:hover .nav-megamenu,
  .nav-megamenu-wrapper:focus-within .nav-megamenu {
    display: flex;
    gap: 2rem;
  }

  .nav-megamenu__column {
    flex: 1;
    min-width: 100px;
  }

  .nav-megamenu__heading {
    display: block;
    color: white;
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-bottom: 0.6rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }

  .nav-megamenu__heading:hover {
    opacity: 0.8;
  }

  .nav-megamenu__list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  .nav-megamenu__item {
    display: block;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.35rem 0;
    transition: color 0.1s ease;
  }

  .nav-megamenu__item:hover {
    color: white;
  }

  @media screen and (max-width: 991px) {
    .nav-megamenu {
      display: none !important;
    }
  }

  /* Middle column - Logo/Heading */
  .header__heading {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Right column - Icons */
  .header__icons {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .header__heading .h2 {
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: inherit;
    font-weight: bold;
  }

  /* Drawer menu styles */
  .drawer-menu__link,
  .drawer-menu__sublink {
    color: white;
  }
  
  .drawer-menu__link:hover,
  .drawer-menu__sublink:hover {
    color: rgba(255, 255, 255, 0.8);
  }
{%- endstyle -%}

<!-- Existing JS (header-scroll) -->
<script src="{{ 'header-scroll.js' | asset_url }}" defer></script>

<header-scroll>
  <header class="header">
    <!-- Desktop menu -->
    <div class="header__inline-menu header__inline-menu--desktop">
      {%- assign drawer_menu = section.settings.drawer_menu -%}
      {%- for link in section.settings.menu.links -%}
        {%- assign link_handle = link.title | downcase -%}
        {%- if link_handle == 'shop' and drawer_menu.links.size > 0 -%}
          <div class="nav-megamenu-wrapper">
            <button type="button" class="header__menu-button" aria-expanded="false" aria-haspopup="true">
              {{- link.title -}}
            </button>
            <div class="nav-megamenu" role="navigation" aria-label="Shop categories">
              {%- for category in drawer_menu.links -%}
                <div class="nav-megamenu__column">
                  <a href="{{ category.url }}" class="nav-megamenu__heading">{{ category.title }}</a>
                  {%- if category.links.size > 0 -%}
                    <ul class="nav-megamenu__list">
                      {%- for sublink in category.links -%}
                        <li>
                          <a href="{{ sublink.url }}" class="nav-megamenu__item">{{ sublink.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- elsif link.links.size > 0 -%}
          <div class="nav-dropdown">
            <button type="button" class="header__menu-button" aria-expanded="false" aria-haspopup="true">
              {{- link.title -}}
            </button>
            <ul class="nav-dropdown__menu">
              {%- for child in link.links -%}
                <li>
                  <a href="{{ child.url }}" class="nav-dropdown__item">{{ child.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="header__menu-button" style="text-decoration: none;">
            {{- link.title -}}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Mobile header -->
    <div class="header__inline-menu--mobile">
      <div class="mobile-left-group">
        <button type="button" class="header__hamburger" id="mobile-menu-toggle" aria-label="Open Navigation">
          <svg class="icon-hamburger" width="24" height="24" viewBox="0 0 24 24">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2"/>
          </svg>
          <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2"/>
          </svg>
        </button>
        
        {% render 'header-search', input_id: 'Search-In-Mobile' %}
      </div>

      <div class="mobile-right-group">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="header__icon header__icon--account">
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}

        <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart" id="cart-icon-bubble-mobile">
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
          {%- if cart != empty -%}
            <div class="cart-count-bubble">
              {%- if cart.item_count < 100 -%}
                <span aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </a>
      </div>
    </div>

    <!-- Logo -->
    <div class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link">
        <span class="h2">SPAWN FLY FISH</span>
      </a>
    </div>

    <!-- Desktop icons -->
    <div class="header__icons">
      {% render 'header-search', input_id: 'Search-In-Desktop' %}
      
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon header__icon--account">
          <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart" id="cart-icon-bubble">
        <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </a>
    </div>

    {% render 'drawer-menu', menu: section.settings.drawer_menu %}
  </header>
</header-scroll>

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "link_list",
      "id": "drawer_menu",
      "label": "Drawer menu (Shop categories)"
    }
  ]
}
{% endschema %}