{{ 'section-product-editorial.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign editorial_content = section.settings.content
  if editorial_content == blank and section.settings.use_description_fallback
    assign editorial_content = product.description
  endif

  assign editorial_heading = section.settings.heading
  if editorial_heading == blank
    assign editorial_heading = section.settings.fallback_heading
  endif

  comment
    Split the description into an intro row and per-heading columns.
    Descriptions follow the house structure: intro paragraphs, then
    '<h2>Key Features</h2><ul>…' and '<h2>Product Details</h2><ul>…'.
    Unrecognized <h2> segments stay with the intro row.
  endcomment
  assign intro_html = editorial_content
  assign key_features_html = ''
  assign product_details_html = ''
  if editorial_content contains '<h2'
    assign parts = editorial_content | split: '<h2'
    assign intro_html = parts[0]
    for part in parts offset: 1
      assign segment = '<h2' | append: part
      assign segment_head = part | split: '</h2>' | first | downcase
      if segment_head contains 'key features'
        assign key_features_html = segment
      elsif segment_head contains 'product details'
        assign product_details_html = segment
      else
        assign intro_html = intro_html | append: segment
      endif
    endfor
  endif

  assign intro_text = intro_html | strip_html | strip
  assign shipping_text = section.settings.shipping_text
-%}

{%- if editorial_content != blank -%}
  <div class="gradient color-{{ section.settings.color_scheme }}">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="product-editorial">
        {%- if editorial_heading != blank -%}
          <h2 class="product-editorial__heading">{{ editorial_heading }}</h2>
        {%- endif -%}

        {%- if intro_text != blank -%}
          <div class="product-editorial__body rte">
            {{ intro_html }}
          </div>
        {%- endif -%}

        {%- if key_features_html != blank or product_details_html != blank or product.vendor != blank or shipping_text != blank -%}
          <div class="product-editorial__columns">
            {%- if key_features_html != blank -%}
              <div class="product-editorial__column rte">
                {{ key_features_html }}
              </div>
            {%- endif -%}
            {%- if product_details_html != blank -%}
              <div class="product-editorial__column rte">
                {{ product_details_html }}
              </div>
            {%- endif -%}
            {%- if product.vendor != blank or shipping_text != blank -%}
              <div class="product-editorial__column product-editorial__column--stacked">
                {%- if product.vendor != blank -%}
                  <div class="product-editorial__stack-item rte">
                    <h2>{{ section.settings.brand_heading | escape }}</h2>
                    <p>{{ product.vendor }}</p>
                  </div>
                {%- endif -%}
                {%- if shipping_text != blank -%}
                  <div class="product-editorial__stack-item rte">
                    <h2>{{ section.settings.shipping_heading | escape }}</h2>
                    {{ shipping_text }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.product-editorial.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.product-editorial.settings.heading.label",
      "info": "t:sections.product-editorial.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:sections.product-editorial.settings.content.label",
      "info": "t:sections.product-editorial.settings.content.info"
    },
    {
      "type": "checkbox",
      "id": "use_description_fallback",
      "default": true,
      "label": "t:sections.product-editorial.settings.use_description_fallback.label",
      "info": "t:sections.product-editorial.settings.use_description_fallback.info"
    },
    {
      "type": "text",
      "id": "fallback_heading",
      "default": "t:sections.product-editorial.settings.fallback_heading.default",
      "label": "t:sections.product-editorial.settings.fallback_heading.label",
      "info": "t:sections.product-editorial.settings.fallback_heading.info"
    },
    {
      "type": "text",
      "id": "brand_heading",
      "default": "t:sections.product-editorial.settings.brand_heading.default",
      "label": "t:sections.product-editorial.settings.brand_heading.label"
    },
    {
      "type": "text",
      "id": "shipping_heading",
      "default": "t:sections.product-editorial.settings.shipping_heading.default",
      "label": "t:sections.product-editorial.settings.shipping_heading.label"
    },
    {
      "type": "richtext",
      "id": "shipping_text",
      "default": "t:sections.product-editorial.settings.shipping_text.default",
      "label": "t:sections.product-editorial.settings.shipping_text.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.product-editorial.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.product-editorial.settings.padding_top.label",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.product-editorial.settings.padding_bottom.label",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-editorial.presets.name"
    }
  ]
}
{% endschema %}
