{{ 'section-product-specs.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign visible_blocks = 0
  for block in section.blocks
    if block.settings.content != blank
      assign visible_blocks = visible_blocks | plus: 1
    endif
  endfor
-%}

{%- if visible_blocks > 0 -%}
  <div class="gradient color-{{ section.settings.color_scheme }}">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="product-specs">
        {%- if section.settings.heading != blank -%}
          <h2 class="product-specs__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        <dl class="product-specs__grid">
          {%- for block in section.blocks -%}
            {%- if block.settings.content == blank -%}
              {%- continue -%}
            {%- endif -%}
            <div
              class="product-specs__item{% if block.settings.wide %} product-specs__item--wide{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.heading != blank -%}
                <dt class="product-specs__heading">{{ block.settings.heading | escape }}</dt>
              {%- endif -%}
              <dd class="product-specs__content rte">{{ block.settings.content }}</dd>
            </div>
          {%- endfor -%}
        </dl>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.product-specs.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.product-specs.settings.heading.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.product-specs.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.product-specs.settings.padding_top.label",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.product-specs.settings.padding_bottom.label",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "t:sections.product-specs.blocks.spec.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "t:sections.product-specs.blocks.spec.settings.heading.default",
          "label": "t:sections.product-specs.blocks.spec.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.product-specs.blocks.spec.settings.content.label",
          "info": "t:sections.product-specs.blocks.spec.settings.content.info"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "default": false,
          "label": "t:sections.product-specs.blocks.spec.settings.wide.label",
          "info": "t:sections.product-specs.blocks.spec.settings.wide.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-specs.presets.name",
      "blocks": [
        {
          "type": "spec"
        },
        {
          "type": "spec"
        },
        {
          "type": "spec"
        }
      ]
    }
  ]
}
{% endschema %}
