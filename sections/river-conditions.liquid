{{ 'river-conditions.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'quick-add.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<script src="{{ 'river-conditions.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign river = page.metafields.custom.river.value -%}

{%- if river == blank -%}
  <div class="river-conditions river-conditions--empty page-width section-{{ section.id }}-padding">
    <p class="river-conditions__empty-state">{{ 'sections.river_conditions.no_river' | t: default: 'No river data configured for this page.' }}</p>
  </div>
{%- else -%}

  {%- comment -%} Per-river static data fallbacks (coordinates, access points, nearest).
                 When these land as metaobject fields, prefer river.<field> over these. {%- endcomment -%}
  {%- assign map_lat = blank -%}
  {%- assign map_lng = blank -%}
  {%- assign map_zoom = '12' -%}
  {%- capture access_raw -%}{%- endcapture -%}
  {%- capture nearest_raw -%}{%- endcapture -%}
  {%- capture stretch_raw -%}{%- endcapture -%}
  {%- case river.slug -%}
    {%- when 'yakima' -%}
      {%- assign map_lat = '46.8621' -%}
      {%- assign map_lng = '-120.4716' -%}
      {%- capture access_raw -%}Red's Meadow|MI 21
Big Pines|MI 15
Umtanum Rec. Area|MI 9
Ringer Loop|MI 6
Roza Dam|MI 3{%- endcapture -%}
      {%- capture nearest_raw -%}Yakima, WA|22 mi SE
Ellensburg, WA|18 mi NW
SEA airport|141 mi W{%- endcapture -%}
      {%- capture stretch_raw -%}Canyon between <strong>Big Pines</strong> and <strong>Umtanum</strong> — seams holding fish, skwalas coming off mid-day.{%- endcapture -%}
  {%- endcase -%}

  {%- assign access_lines = access_raw | split: '
' -%}
  {%- assign nearest_lines = nearest_raw | split: '
' -%}

  {%- comment -%} Nav tabs {%- endcomment -%}
  {%- assign river_links = section.blocks | where: 'type', 'river_link' -%}
  {%- if river_links.size > 0 -%}
    <nav class="river-nav page-width" aria-label="{{ 'sections.river_conditions.river_navigation' | t: default: 'River navigation' }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'river_link' -%}
          <a
            href="{{ block.settings.url }}"
            class="river-nav__link{% if block.settings.url == request.path %} river-nav__link--active{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{- block.settings.label | escape -}}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}

  {%- comment -%} Hero {%- endcomment -%}
  <div class="river-hero">
    {%- if river.hero_image != blank -%}
      <div class="river-hero__image-wrapper">
        {{ river.hero_image | image_url: width: 1500 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          preload: true,
          widths: '375,750,1100,1500',
          sizes: '100vw',
          class: 'river-hero__image',
          alt: river.hero_image.alt | default: river.name | escape
        }}
      </div>
    {%- endif -%}
    <span class="river-hero__scrim-label">{{ 'sections.river_conditions.live_label' | t: default: 'Live · USGS 15-min feed' }}</span>
    <div class="river-hero__overlay">
      <div class="river-hero__overlay-inner page-width">
        <h1 class="river-hero__title">{{ river.name | escape }}</h1>
        {%- if river.description != blank -%}
          <p class="river-hero__lede">{{ river.description | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="river-conditions page-width section-{{ section.id }}-padding">

    {%- comment -%} Dateline {%- endcomment -%}
    <header class="river-dateline">
      <div class="river-dateline__meta">
        {%- if river.region != blank -%}<span>{{ river.region | escape }}</span>{% endif -%}
        <span>{{- 'now' | date: '%m.%d.%y' -}}</span>
        {%- if river.usgs_station_id != blank -%}<span>USGS {{ river.usgs_station_id | escape }}</span>{%- endif -%}
      </div>
    </header>

    <river-conditions data-section-id="{{ section.id }}">

      {%- comment -%} Conditions: hero flow + secondary rows {%- endcomment -%}
      <section class="river-conditions__block">
        <div class="river-metrics">
          <div class="river-metric--hero river-metric--loading" data-condition="flow">
            <div class="river-metric__label">{{ 'sections.river_conditions.flow' | t: default: 'Streamflow' }}</div>
            <div class="river-metric__value-row">
              <span class="river-metric__value" aria-live="polite">—</span>
              <span class="river-metric__unit">cfs</span>
            </div>
            <div class="river-metric__sub">cubic feet per second</div>
          </div>

          <div class="river-secondary-rows">
            <div class="river-secondary-row" data-condition="gage">
              <span class="river-secondary-row__label">{{ 'sections.river_conditions.gage_height' | t: default: 'Gage height' }}</span>
              <span class="river-secondary-row__value" aria-live="polite">—<span class="unit">ft</span></span>
            </div>
            <div class="river-secondary-row" data-condition="temp">
              <span class="river-secondary-row__label">{{ 'sections.river_conditions.temperature' | t: default: 'Water temperature' }}</span>
              <span class="river-secondary-row__value" aria-live="polite">—<span class="unit">°F</span></span>
            </div>
            <div class="river-secondary-row">
              <span class="river-secondary-row__label">{{ 'sections.river_conditions.clarity' | t: default: 'Clarity' }}</span>
              <span class="river-secondary-row__value">
                {%- if river.current_clarity != blank -%}
                  {{ river.current_clarity | escape }}
                  {%- if river.clarity_visibility != blank -%}
                    <span class="unit">{{ river.clarity_visibility | escape }}</span>
                  {%- endif -%}
                {%- else -%}—{%- endif -%}
              </span>
            </div>
          </div>
        </div>
      </section>

      {%- comment -%} Fishability banner — hidden until JS computes {%- endcomment -%}
      <section class="river-fishability" hidden aria-label="Fishability rating">
        <span class="river-fishability__rating"></span>
        <span class="river-fishability__subtitle"></span>
        <span class="river-fishability__updated" aria-live="polite"></span>
      </section>

      <p class="river-conditions__fallback" hidden>
        {{ 'sections.river_conditions.data_unavailable' | t: default: 'Live conditions temporarily unavailable. Check back soon.' }}
      </p>

      {%- comment -%} Field data: flow chart + map, side by side {%- endcomment -%}
      <div class="river-field-data">

        <section class="river-flow">
          <div class="river-field-data__header">
            <h2 class="river-field-data__heading">{{ 'sections.river_conditions.flow_history' | t: default: '7-Day Discharge' }}</h2>
            <span class="river-field-data__sub">
              {%- if river.usgs_station_id != blank -%}USGS {{ river.usgs_station_id }} · {%- endif -%}
              cfs · 15-min
            </span>
          </div>
          <div class="river-flow__chart-wrap">
            <div class="river-flow__chart river-flow__chart--loading" data-flow-chart></div>
            <div class="river-flow__legend">
              <span class="river-flow__legend-item"><span class="river-flow__legend-swatch river-flow__legend-swatch--line"></span>Discharge</span>
              <span class="river-flow__legend-item"><span class="river-flow__legend-swatch river-flow__legend-swatch--prime"></span>Prime window</span>
              <span class="river-flow__legend-item"><span class="river-flow__legend-swatch river-flow__legend-swatch--blown"></span>Blown-out</span>
            </div>
          </div>
          <p class="river-flow__trend" data-flow-trend hidden></p>
        </section>

        {%- if map_lat != blank and map_lng != blank -%}
          <section class="river-locator">
            <div class="river-field-data__header">
              <h2 class="river-field-data__heading">{{ 'sections.river_conditions.where' | t: default: "Where You're Fishing" }}</h2>
              <span class="river-field-data__sub">{{ map_lat }}° N · {{ map_lng | remove: '-' }}° W</span>
            </div>
            <div class="river-locator__map-wrap">
              <iframe
                class="river-locator__map-frame"
                src="https://maps.google.com/maps?q={{ map_lat }},{{ map_lng }}&t=p&z={{ map_zoom }}&output=embed"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="{{ river.name | escape }} location"></iframe>
              <a class="river-locator__map-open"
                 href="https://www.google.com/maps/search/?api=1&query={{ map_lat }},{{ map_lng }}"
                 target="_blank" rel="noopener">Open in Google Maps ↗</a>
            </div>
          </section>
        {%- endif -%}
      </div>

      {%- if access_lines.size > 0 or nearest_lines.size > 0 or stretch_raw != blank -%}
        <section class="river-field-footer">
          {%- if access_lines.size > 0 -%}
            <div>
              <div class="river-field-footer__label">{{ 'sections.river_conditions.access_points' | t: default: 'Access Points · Upstream → Down' }}</div>
              <ul class="river-access">
                {%- for line in access_lines -%}
                  {%- assign parts = line | split: '|' -%}
                  <li>
                    <span class="river-access__marker">{{ forloop.index }}</span>
                    <span>{{ parts[0] | strip | escape }}</span>
                    <span class="river-access__dist">{{ parts[1] | strip | escape }}</span>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
          {%- if nearest_lines.size > 0 -%}
            <div>
              <div class="river-field-footer__label">{{ 'sections.river_conditions.nearest' | t: default: 'Nearest' }}</div>
              <ul class="river-nearest">
                {%- for line in nearest_lines -%}
                  {%- assign parts = line | split: '|' -%}
                  <li>
                    <span>{{ parts[0] | strip | escape }}</span>
                    <span class="river-nearest__dist">{{ parts[1] | strip | escape }}</span>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
          {%- if stretch_raw != blank -%}
            <div>
              <div class="river-field-footer__label">{{ 'sections.river_conditions.best_stretch' | t: default: 'Best stretch right now' }}</div>
              <p class="river-field-footer__meta">{{ stretch_raw }}</p>
            </div>
          {%- endif -%}
        </section>
      {%- endif -%}

    </river-conditions>

    {%- comment -%} Guide report {%- endcomment -%}
    {%- if river.guide_notes != blank -%}
      <section class="river-log">
        <div class="river-log__header">
          <h2 class="river-log__heading">{{ 'sections.river_conditions.guide_report' | t: default: 'Guide Report' }}</h2>
          {%- if river.guide_notes_date != blank -%}
            <time class="river-log__date" datetime="{{ river.guide_notes_date }}">
              Entry · {{ river.guide_notes_date | date: '%m.%d.%Y' }}
            </time>
          {%- endif -%}
        </div>
        <div class="river-log__body rte">{{ river.guide_notes }}</div>
      </section>
    {%- endif -%}

    {%- comment -%} Hatches {%- endcomment -%}
    {%- assign hatches = river.hatches.value -%}
    {%- assign month_names = 'Jan,Feb,Mar,Apr,May,Jun,Jul,Aug,Sep,Oct,Nov,Dec' | split: ',' -%}
    {%- assign current_month = 'now' | date: '%-m' | plus: 0 -%}

    {%- if hatches != blank -%}
      <section class="river-hatches">
        <div class="river-hatches__header">
          <h2 class="river-hatches__heading">{{ 'sections.river_conditions.on_the_water' | t: default: 'On the Water Now' }}</h2>
          <span class="river-hatches__sub">{{ hatches | size }} tracked · Pacific time</span>
        </div>
        <div class="river-hatch-list">
          {%- for hatch in hatches -%}
            {%- assign h_start = hatch.season_start_month | plus: 0 -%}
            {%- assign h_end = hatch.season_end_month | plus: 0 -%}
            {%- assign in_season = false -%}
            {%- if h_start <= h_end -%}
              {%- if current_month >= h_start and current_month <= h_end -%}{%- assign in_season = true -%}{%- endif -%}
            {%- else -%}
              {%- if current_month >= h_start or current_month <= h_end -%}{%- assign in_season = true -%}{%- endif -%}
            {%- endif -%}
            {%- if in_season -%}
              {%- assign initial_status = 'In window' -%}
              {%- assign hatch_class = 'river-hatch' -%}
            {%- else -%}
              {%- assign initial_status = 'Off-season' -%}
              {%- assign hatch_class = 'river-hatch river-hatch--inactive' -%}
            {%- endif -%}
            <article
              class="{{ hatch_class }}"
              data-hatch-index="{{ forloop.index0 }}"
              data-season-start="{{ hatch.season_start_month }}"
              data-season-end="{{ hatch.season_end_month }}"
            >
              <svg class="river-hatch__silhouette" viewBox="0 0 60 30" fill="currentColor" aria-hidden="true">
                <ellipse cx="30" cy="15" rx="8" ry="3" />
                <path d="M 30 12 Q 20 4, 10 8 Q 18 10, 28 14" opacity="0.7" />
                <path d="M 30 12 Q 40 4, 50 8 Q 42 10, 32 14" opacity="0.7" />
                <path d="M 30 18 Q 22 24, 14 22 Q 22 20, 28 17" opacity="0.5" />
                <path d="M 30 18 Q 38 24, 46 22 Q 38 20, 32 17" opacity="0.5" />
                <line x1="38" y1="15" x2="46" y2="13" stroke="currentColor" stroke-width="0.6" />
                <line x1="38" y1="16" x2="46" y2="17" stroke="currentColor" stroke-width="0.6" />
              </svg>
              <div>
                <h3 class="river-hatch__name">
                  {{ hatch.bug_name | escape }}
                  {%- if hatch.latin_name != blank -%}
                    <span class="river-hatch__latin">{{ hatch.latin_name | escape }}</span>
                  {%- endif -%}
                </h3>
                <div class="river-hatch__spec">
                  {%- assign start_idx = hatch.season_start_month | minus: 1 -%}
                  {%- assign end_idx = hatch.season_end_month | minus: 1 -%}
                  <span>{{ month_names[start_idx] }}–{{ month_names[end_idx] }}</span>
                  {%- if hatch.min_water_temp_f != blank and hatch.max_water_temp_f != blank -%}
                    <span>{{ hatch.min_water_temp_f }}–{{ hatch.max_water_temp_f }}°F</span>
                  {%- endif -%}
                  {%- if hatch.peak_time_start != blank and hatch.peak_time_end != blank -%}
                    <span>{{ hatch.peak_time_start }}–{{ hatch.peak_time_end }}</span>
                  {%- endif -%}
                  {%- if hatch.lifecycle_stage != blank -%}
                    <span>{{ hatch.lifecycle_stage | escape }}</span>
                  {%- endif -%}
                </div>
              </div>
              <div class="river-hatch__status" data-hatch-status>{{ initial_status }}</div>
            </article>
          {%- endfor -%}
        </div>
      </section>
    {%- else -%}
      <section class="river-hatches river-hatches--empty">
        <p>{{ 'sections.river_conditions.no_hatches' | t: default: 'No active hatches right now. Check back soon or browse the full fly box below.' }}</p>
      </section>
    {%- endif -%}

    {%- comment -%} Gear {%- endcomment -%}
    {%- if hatches != blank -%}
      {%- assign seen_ids = '' -%}
      {%- assign has_products = false -%}
      {%- for hatch in hatches -%}
        {%- assign hatch_products = hatch.recommended_products.value -%}
        {%- if hatch_products != blank -%}
          {%- for product in hatch_products -%}
            {%- assign id_check = product.id | append: ',' -%}
            {%- unless seen_ids contains id_check -%}
              {%- assign has_products = true -%}
              {%- break -%}
            {%- endunless -%}
          {%- endfor -%}
          {%- if has_products -%}{%- break -%}{%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_products -%}
        <section class="river-gear">
          <h2 class="river-gear__heading">{{ 'sections.river_conditions.recommended_gear' | t: default: 'Recommended Ties' }}</h2>
          <p class="river-gear__lede">{{ 'sections.river_conditions.gear_lede' | t: default: "Matched to what's on the water right now." }}</p>
          <ul class="river-gear-grid list-unstyled" role="list">
            {%- assign seen_ids = '' -%}
            {%- assign skip_card_styles = false -%}
            {%- for hatch in hatches -%}
              {%- assign hatch_products = hatch.recommended_products.value -%}
              {%- if hatch_products != blank -%}
                {%- for product in hatch_products -%}
                  {%- assign id_check = product.id | append: ',' -%}
                  {%- unless seen_ids contains id_check -%}
                    {%- assign seen_ids = seen_ids | append: id_check -%}
                    <li class="river-gear-grid__item">
                      {% render 'card-product',
                        card_product: product,
                        media_aspect_ratio: 'square',
                        show_secondary_image: true,
                        show_vendor: false,
                        show_rating: false,
                        skip_styles: skip_card_styles,
                        section_id: section.id,
                        quick_add: section.settings.quick_add
                      %}
                    </li>
                    {%- assign skip_card_styles = true -%}
                  {%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </section>
      {%- endif -%}
    {%- endif -%}

  </div>

  {%- if hatches != blank -%}
    <script type="application/json" id="river-hatches-data-{{ section.id }}">
      [
        {%- for hatch in hatches -%}
          {
            "bug_name": {{ hatch.bug_name | json }},
            "season_start_month": {{ hatch.season_start_month | default: 1 }},
            "season_end_month": {{ hatch.season_end_month | default: 12 }},
            "min_water_temp_f": {{ hatch.min_water_temp_f | default: 0 }},
            "max_water_temp_f": {{ hatch.max_water_temp_f | default: 100 }},
            "peak_time_start": {{ hatch.peak_time_start | json }},
            "peak_time_end": {{ hatch.peak_time_end | json }},
            "lifecycle_stage": {{ hatch.lifecycle_stage | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    </script>
  {%- endif -%}

  <script type="application/json" id="river-config-data-{{ section.id }}">
    {
      "station_id": {{ river.usgs_station_id | json }},
      "worker_url": "https://usgs-proxy.doss-fpmo.workers.dev",
      "slug": {{ river.slug | json }}
    }
  </script>

{%- endif -%}

{% schema %}
{
  "name": "t:sections.river_conditions.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.river_conditions.settings.header_layout.content",
      "info": "t:sections.river_conditions.settings.header_layout.info"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "header",
      "content": "t:sections.river_conditions.settings.header_products.content"
    },
    {
      "type": "select",
      "id": "quick_add",
      "label": "t:sections.featured_collection.settings.quick_add.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "t:sections.featured_collection.settings.quick_add.options__1.label"
        },
        {
          "value": "none",
          "label": "t:sections.featured_collection.settings.quick_add.options__3.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "river_link",
      "name": "t:sections.river_conditions.blocks.river_link.name",
      "settings": [
        {
          "type": "url",
          "id": "url",
          "label": "t:sections.river_conditions.blocks.river_link.settings.url.label",
          "default": "/"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.river_conditions.blocks.river_link.settings.label.label",
          "default": "River Name"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "max_blocks": 15,
  "presets": [
    {
      "name": "t:sections.river_conditions.name"
    }
  ]
}
{% endschema %}
